; Engine configuration file.
; Prefer editing this file through the Godot editor when possible.

config_version=5

[application]

config/name="Pavillon Libre"
config/description="Original pirate adventure prototype built with primitive Godot assets."
run/main_scene="res://scenes/world/World.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[rendering]

renderer/rendering_method="forward_plus"
